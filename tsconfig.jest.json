{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "lib": ["dom", "dom.iterable", "esnext"],
    "types": [
      "jest",
      "@testing-library/jest-dom",
      "@testing-library/react",
      "node"
    ],
    "esModuleInterop": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "jest.config.ts",
    "jest.setup.ts",
    "jest.d.ts",
    "src/**/__tests__/**/*.{ts,tsx}",
    "src/**/*.{spec,test}.{ts,tsx}"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}